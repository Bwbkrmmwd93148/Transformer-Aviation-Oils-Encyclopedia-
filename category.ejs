<!DOCTYPE html>
<html lang="<%= language %>" dir="<%= language === 'ar' ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <h1>أبو بكر محمود</h1>
            </div>
            <ul class="nav-menu">
                <li><a href="/" class="nav-link">الرئيسية</a></li>
                <li><a href="/about" class="nav-link">عن الموقع</a></li>
                <li><a href="/contact" class="nav-link">اتصل بنا</a></li>
            </ul>
            <button class="lang-toggle" onclick="toggleLanguage()"><%= language === 'ar' ? 'EN' : 'AR' %></button>
        </div>
    </nav>

    <!-- Category Header -->
    <section style="background: linear-gradient(135deg, var(--primary-color) 0%, var(--accent-color) 100%); color: white; padding: 3rem 0; text-align: center;">
        <div class="container">
            <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;"><%= category.slug.replace(/-/g, ' ') %></h1>
            <p>عدد المقالات: <%= articles.length %></p>
        </div>
    </section>

    <!-- Articles Grid -->
    <section style="padding: 3rem 0;">
        <div class="container">
            <div class="grid">
                <% articles.forEach(article => { %>
                    <div class="article-card">
                        <% if (article.featured_image) { %>
                            <img src="<%= article.featured_image %>" alt="<%= article.title %>" class="article-image">
                        <% } %>
                        <div class="article-content">
                            <h3><%= article.title %></h3>
                            <p class="article-meta">
                                <span><%= new Date(article.created_at).toLocaleDateString('ar-SA') %></span>
                                <span> | </span>
                                <span><%= article.views_count %> مشاهدة</span>
                            </p>
                            <p><%= article.description || article.content.substring(0, 150) %>...</p>
                            <a href="/articles/<%= article.slug %>" class="btn btn-primary">اقرأ المزيد</a>
                        </div>
                    </div>
                <% }); %>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
                <div style="display: flex; justify-content: center; gap: 0.5rem; margin-top: 2rem; flex-wrap: wrap;">
                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a href="?page=<%= i %>" class="btn <%= i === page ? 'btn-primary' : 'btn-secondary' %>"><%= i %></a>
                    <% } %>
                </div>
            <% } %>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 أبو بكر محمود - جميع الحقوق محفوظة</p>
        </div>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
